# HomeFlex Docker Compose environment template.
# Copy to .env for local development and replace placeholder secrets before sharing or deploying.

JWT_SECRET=change-me-development-jwt-secret-at-least-32-chars
PII_ENCRYPTION_KEY=MTIzNDU2Nzg5MDEyMzQ1Njc4OTAxMjM0NTY3ODkwMTI=
MONITORING_METRICS_TOKEN=change-me-metrics-token
SPRING_PROFILES_ACTIVE=dev
ADMIN_PASSWORD=change-me-admin-password

# PostgreSQL
DB_USERNAME=postgres
DB_PASSWORD=postgres

# RabbitMQ
SPRING_RABBITMQ_USERNAME=guest
SPRING_RABBITMQ_PASSWORD=guest

# Elasticsearch
ELASTIC_PASSWORD=changeme

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:8001,http://localhost:4200

# MinIO
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=minioadmin

# Backend storage targeting MinIO
AWS_ENABLED=true
AWS_ACCESS_KEY=admin
AWS_SECRET_KEY=minioadmin
AWS_REGION=us-east-1
AWS_S3_BUCKET=rental-app-media
AWS_S3_ENDPOINT=http://minio:9000
