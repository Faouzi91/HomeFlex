{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Application Up",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "up{job=\"homeflex-backend\"}",
          "legendFormat": "Backend"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "datasource": "Prometheus"
    },
    {
      "title": "CPU Usage",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [
        {
          "expr": "system_cpu_usage{job=\"homeflex-backend\"}",
          "legendFormat": "System CPU"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "datasource": "Prometheus"
    },
    {
      "title": "JVM Heap Used",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\", job=\"homeflex-backend\"} / jvm_memory_max_bytes{area=\"heap\", job=\"homeflex-backend\"}",
          "legendFormat": "Heap %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "datasource": "Prometheus"
    },
    {
      "title": "Bookings Created",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "homeflex_bookings_created_total{job=\"homeflex-backend\"}",
          "legendFormat": "Total"
        }
      ],
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [{ "color": "blue", "value": null }] } }
      },
      "datasource": "Prometheus"
    },
    {
      "title": "Payment Outcomes",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "homeflex_bookings_payments_total{outcome=\"success\", job=\"homeflex-backend\"}",
          "legendFormat": "Succeeded"
        },
        {
          "expr": "homeflex_bookings_payments_total{outcome=\"failure\", job=\"homeflex-backend\"}",
          "legendFormat": "Failed"
        }
      ],
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }] } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Failed" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "datasource": "Prometheus"
    },
    {
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{job=\"homeflex-backend\"}[1m])",
          "legendFormat": "{{method}} {{uri}} [{{status}}]"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "datasource": "Prometheus"
    },
    {
      "title": "HTTP Response Time (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{job=\"homeflex-backend\"}[5m]))",
          "legendFormat": "{{method}} {{uri}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "datasource": "Prometheus"
    },
    {
      "title": "JVM Heap Memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\", job=\"homeflex-backend\"}",
          "legendFormat": "Used — {{id}}"
        },
        {
          "expr": "jvm_memory_committed_bytes{area=\"heap\", job=\"homeflex-backend\"}",
          "legendFormat": "Committed — {{id}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "datasource": "Prometheus"
    },
    {
      "title": "JVM GC Pause Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{job=\"homeflex-backend\"}[1m])",
          "legendFormat": "{{action}} — {{cause}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "datasource": "Prometheus"
    },
    {
      "title": "JVM Threads",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{job=\"homeflex-backend\"}",
          "legendFormat": "Live"
        },
        {
          "expr": "jvm_threads_daemon_threads{job=\"homeflex-backend\"}",
          "legendFormat": "Daemon"
        },
        {
          "expr": "jvm_threads_peak_threads{job=\"homeflex-backend\"}",
          "legendFormat": "Peak"
        }
      ],
      "datasource": "Prometheus"
    },
    {
      "title": "HikariCP Connection Pool",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "hikaricp_connections_active{job=\"homeflex-backend\"}",
          "legendFormat": "Active"
        },
        {
          "expr": "hikaricp_connections_idle{job=\"homeflex-backend\"}",
          "legendFormat": "Idle"
        },
        {
          "expr": "hikaricp_connections_pending{job=\"homeflex-backend\"}",
          "legendFormat": "Pending"
        }
      ],
      "datasource": "Prometheus"
    },
    {
      "title": "Booking & Payment Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "targets": [
        {
          "expr": "rate(homeflex_bookings_created_total{job=\"homeflex-backend\"}[5m])",
          "legendFormat": "Bookings / sec"
        },
        {
          "expr": "rate(homeflex_bookings_payments_total{outcome=\"success\", job=\"homeflex-backend\"}[5m])",
          "legendFormat": "Payments succeeded / sec"
        },
        {
          "expr": "rate(homeflex_bookings_payments_total{outcome=\"failure\", job=\"homeflex-backend\"}[5m])",
          "legendFormat": "Payments failed / sec"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Payments failed / sec" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "datasource": "Prometheus"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["homeflex", "spring-boot", "jvm"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "HomeFlex — JVM & Application Health",
  "uid": "homeflex-overview",
  "version": 1
}
