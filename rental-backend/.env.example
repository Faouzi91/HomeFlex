# ============================================================
# HomeFlex Backend — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# JWT — must be at least 32 characters, randomly generated
JWT_SECRET=

# Admin account created on first startup
ADMIN_EMAIL=admin@homeflex.com
ADMIN_PASSWORD=

# Database
DB_USERNAME=postgres
DB_PASSWORD=

# RabbitMQ
SPRING_RABBITMQ_USERNAME=guest
SPRING_RABBITMQ_PASSWORD=

# PII encryption key (AES-256-GCM, base64-encoded 32-byte key)
PII_ENCRYPTION_KEY=

# Email (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# AWS S3
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# MinIO (Docker Compose local object storage)
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=

# Elasticsearch
ELASTIC_PASSWORD=

# Prometheus metrics scrape token
METRICS_TOKEN=

# Twilio (SMS/WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
